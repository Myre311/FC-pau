# =====================================================================
# FC Pau — Variables d'environnement (modèle)
# Copier ce fichier en `.env.local` et remplir les valeurs.
# JAMAIS commiter `.env.local`.
# =====================================================================

# --- Application ----------------------------------------------------
# URL publique du site (sans slash final)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Environnement logique (development | staging | production)
APP_ENV=development

# --- Supabase (BDD + Auth + Storage + Realtime) ---------------------
# Project URL (public, OK en NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=
# Clé anon (public, OK en NEXT_PUBLIC_) — soumise aux RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service_role (SECRET — bypass RLS — JAMAIS exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma / Postgres (via Supabase) -------------------------------
# Connection pooling (port 6543) — utilisée par l'app en runtime
DATABASE_URL=
# Connection directe (port 5432) — uniquement pour `prisma migrate`
DIRECT_URL=

# --- Stripe ---------------------------------------------------------
# Côté serveur uniquement (SECRET)
STRIPE_SECRET_KEY=
# Côté client (publishable, OK en NEXT_PUBLIC_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (SECRET)
STRIPE_WEBHOOK_SECRET=

# --- POS (Square ou Lightspeed — à choisir) -------------------------
# Token entrant pour authentifier les webhooks POS (SECRET, à comparer en HMAC)
POS_WEBHOOK_SECRET=

# --- Sécurité -------------------------------------------------------
# Origine autorisée pour CORS (séparer par virgules)
ALLOWED_ORIGINS=http://localhost:3000
# Secret pour signer les paniers / sessions custom (SECRET, 64 bytes random)
SESSION_SECRET=

# --- Analytics ------------------------------------------------------
# Google Analytics 4 Measurement ID (ex: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# --- Observabilité (optionnel en dev) -------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
