# =====================================================================
# FC Pau — .gitignore
# Tout secret est exclu par défaut. Si tu doutes, NE COMMIT PAS.
# =====================================================================

# --- Environnement / secrets ----------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.crt
*.pfx
secrets/
.secret
.secrets

# --- Dépendances ----------------------------------------------------
node_modules/
.pnp/
.pnp.js
.yarn/
.npm/
.pnpm-store/

# --- Builds Next.js -------------------------------------------------
.next/
out/
build/
dist/
.vercel/
.turbo/
.swc/

# --- Tests / couverture ---------------------------------------------
coverage/
.nyc_output/
playwright-report/
test-results/
playwright/.cache/

# --- Prisma ---------------------------------------------------------
# On commit le schema, les migrations et le seed, mais PAS le client généré
prisma/.client/
*.db
*.db-journal
*.sqlite
*.sqlite3

# --- Logs -----------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- IDE ------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.recommended.json
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- OS -------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# --- Misc -----------------------------------------------------------
*.bak
*.tmp
*.orig
.cache/
.eslintcache
.stylelintcache
.history/

# --- Claude / outils locaux ----------------------------------------
.claude/local/
.claude/cache/
.claude/settings.local.json

# --- Stripe CLI logs locaux ----------------------------------------
.stripe/

# --- Sentry --------------------------------------------------------
.sentryclirc

.vercel
